---
import { theatreAPI } from "@lib/theatre";
import { canBootstrapTheatreAdmin } from "@lib/admin";

const { user, acc } = Astro.locals;
if (!user) {
  if (await canBootstrapTheatreAdmin())
    return Astro.redirect("/admin/signup", 302);
  return Astro.redirect("/admin/login", 302);
}
if (await acc.isBanned()) return acc.toBan();
if (!user.admin) return Astro.redirect("/admin/login", 302);

// the editor lives in [...id].astro; redirect to the first game in the list
const { entries } = await theatreAPI.list({
  sort: "index",
  includeHidden: true,
});
const first = entries[0];
const page = first
  ? `/admin/theatre/${encodeURIComponent(first.id)}${Astro.url.search}`
  : `/admin/theatre${Astro.url.search}`;
page; // clear unused warning
return Astro.redirect(page, 302);
---
